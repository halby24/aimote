{
  "name": "@acme/desktop-tauri",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "cross-env VITE_E2E=1 vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@acme/app-core": "workspace:*",
    "@acme/host-api-tauri": "workspace:*",
    "@acme/shared-types": "workspace:*",
    "@acme/transport-ws": "workspace:*",
    "@acme/ui-react-web": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "typescript": "*",
    "vite": "^6.2.1"
  }
}
