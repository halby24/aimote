{
  "name": "@acme/ui-reactunity",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:unity": "node scripts/build-unity.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@acme/app-core": "workspace:*",
    "@acme/shared-types": "workspace:*",
    "@acme/transport-relay": "workspace:*",
    "@acme/ui-common": "workspace:*",
    "@reactunity/renderer": "^0.16.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "esbuild": "^0.27.4",
    "typescript": "*"
  }
}
